# ── App config (non-secret, safe to commit) ──────────────────────────────────
APP_VERSION=v1.2
MODEL_NAME=random_forest
# "baseline" uses deterministic z-score heuristic (no pickle needed, good for CI)
# "ml" loads a trained sklearn pipeline from MODEL_PATH
MODEL_VARIANT=baseline
# Injected automatically by CI (${{ github.sha }}); set manually for local runs
GIT_SHA=

# ── Model paths (container-relative in Docker, local paths otherwise) ─────────
MODEL_PATH=/app/models/artifacts/random_forest_pipeline.pkl
BASELINE_CONFIG_PATH=/app/models/artifacts/baseline_zscore_config.json

# ── Kafka ─────────────────────────────────────────────────────────────────────
# Use "kafka:9092" inside Docker Compose, "localhost:9092" for local dev
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── MLflow ────────────────────────────────────────────────────────────────────
# Use "http://mlflow:5000" inside Docker Compose, "http://localhost:5001" locally
MLFLOW_TRACKING_URI=http://localhost:5001

# ── External APIs (only needed if switching to authenticated Coinbase WS) ──────
# COINBASE_API_KEY=
# COINBASE_API_SECRET=
